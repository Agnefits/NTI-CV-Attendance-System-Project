@model Attendance_System.ViewModels.Attendance.EmployeeAttendanceFormViewModel
@{
    ViewData["Title"] = "Log Employee Attendance";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="custom-card">
            <h5 class="card-title mb-4"><i class="bi bi-plus-circle me-1"></i> Log Manual Employee Attendance</h5>
            
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-group mb-3">
                    <label asp-for="EmployeeId" class="form-label">Employee</label>
                    <select asp-for="EmployeeId" asp-items="Model.EmployeeOptions" class="form-select">
                        <option value="">-- Select Employee --</option>
                    </select>
                    <span asp-validation-for="EmployeeId" class="text-danger text-xs"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Status" class="form-label">Attendance Status</label>
                    <select asp-for="Status" asp-items="Model.StatusOptions" class="form-select">
                        <option value="">-- Select Status --</option>
                    </select>
                    <span asp-validation-for="Status" class="text-danger text-xs"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="CameraId" class="form-label">Camera Source (Optional)</label>
                    <select asp-for="CameraId" asp-items="Model.CameraOptions" class="form-select">
                        <option value="">-- System Manual Console --</option>
                    </select>
                    <span asp-validation-for="CameraId" class="text-danger text-xs"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="Note" class="form-label">Notes</label>
                    <textarea asp-for="Note" class="form-control" rows="3" placeholder="Reason for manual log..."></textarea>
                    <span asp-validation-for="Note" class="text-danger text-xs"></span>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4"><i class="bi bi-arrow-left me-1"></i> Cancel</a>
                    <button type="submit" class="btn btn-primary-custom px-4"><i class="bi bi-check-lg me-1"></i> Log Attendance</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
