@model Attendance_System.ViewModels.Attendance.AttendanceDetailsViewModel
@{
    ViewData["Title"] = "Employee Attendance Details";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="custom-card">
            <h5 class="card-title mb-4"><i class="bi bi-clock-history me-1"></i> Employee Attendance Log Record</h5>

            <div class="d-flex align-items-center gap-4 mb-4 pb-3 border-bottom">
                <img src="@(string.IsNullOrEmpty(Model.UserImageUrl) ? "/img/avatar-default.png" : Model.UserImageUrl)" 
                     alt="User Avatar" class="rounded-circle border" 
                     style="width: 70px; height: 70px; object-fit: cover;"
                     onerror="this.src='/img/avatar-default.png'" />
                <div>
                    <h5 class="fw-bold mb-1">@Model.UserFullname</h5>
                    <span class="badge bg-secondary-subtle text-secondary border">@Model.UserType</span>
                    @if (!string.IsNullOrEmpty(Model.UserEmail))
                    {
                        <span class="text-muted text-xs ms-2"><i class="bi bi-envelope"></i> @Model.UserEmail</span>
                    }
                </div>
            </div>

            <div class="row g-3 text-sm mb-4">
                <div class="col-sm-4 text-muted font-medium">Record Status</div>
                <div class="col-sm-8"><partial name="_StatusBadge" model="Model.Status" /></div>

                <div class="col-sm-4 text-muted font-medium">Recorded Date/Time</div>
                <div class="col-sm-8 fw-semibold">@Model.CreatedAt.ToString("f")</div>

                <div class="col-sm-4 text-muted font-medium">Last Modified</div>
                <div class="col-sm-8 fw-semibold">@Model.LastModified.ToString("f")</div>

                <div class="col-sm-4 text-muted font-medium">Detection Mode</div>
                <div class="col-sm-8">
                    @if (Model.ByIA)
                    {
                        <span class="text-indigo fw-bold"><i class="bi bi-cpu me-1"></i> AI Recognition Module</span>
                    }
                    else
                    {
                        <span class="text-muted"><i class="bi bi-pencil me-1"></i> Manual Log Entry</span>
                    }
                </div>

                <div class="col-sm-4 text-muted font-medium">Source / Capture Device</div>
                <div class="col-sm-8 fw-semibold">@(Model.CameraTitle ?? "System Console Manager")</div>

                <div class="col-sm-4 text-muted font-medium">Logged By</div>
                <div class="col-sm-8 fw-semibold">@Model.CreatedByName</div>

                <div class="col-sm-4 text-muted font-medium">Last Edited By</div>
                <div class="col-sm-8 fw-semibold">@Model.ModifiedByName</div>

                <div class="col-sm-4 text-muted font-medium">System Notes</div>
                <div class="col-sm-8">
                    @if (!string.IsNullOrEmpty(Model.Note))
                    {
                        <p class="bg-light p-2.5 rounded border border-light text-xs text-muted mb-0">@Model.Note</p>
                    }
                    else
                    {
                        <span class="text-muted text-xs">No additional details recorded.</span>
                    }
                </div>
            </div>

            <!-- Mock AI Snapshot Capture -->
            @if (Model.ByIA)
            {
                <div class="bg-light border rounded-3 p-3 text-center mb-4">
                    <h6 class="fw-bold text-xs text-muted uppercase text-start mb-2"><i class="bi bi-camera-fill me-1"></i> AI Recognition Camera Snapshot</h6>
                    <div style="position: relative; display: inline-block; max-width: 100%;">
                        <img src="/img/avatar-default.png" alt="Mock Capture" class="border rounded-2" style="max-height: 200px; object-fit: contain;" />
                        <div style="position: absolute; border: 2.5px solid #10B981; top: 25%; left: 35%; width: 30%; height: 50%; box-sizing: border-box; border-radius: 4px;">
                            <span class="badge bg-success text-white text-xxs font-bold" style="position: absolute; top: -20px; left: -2px;">Matched: 98.4%</span>
                        </div>
                    </div>
                </div>
            }

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-outline-secondary px-4"><i class="bi bi-arrow-left me-1"></i> Back to Ledger</a>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary-custom px-4"><i class="bi bi-pencil-square me-1"></i> Edit Log</a>
            </div>
        </div>
    </div>
</div>
