@model Attendance_System.ViewModels.AdminUser.AdminUserFormViewModel
@{
    ViewData["Title"] = "Add Administrator";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="custom-card">
            <h5 class="card-title mb-4"><i class="bi bi-plus-circle me-1"></i> Register New Administrator</h5>
            
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6 form-group">
                        <label asp-for="Username" class="form-label">Username</label>
                        <input asp-for="Username" class="form-control" placeholder="e.g. adminuser" />
                        <span asp-validation-for="Username" class="text-danger text-xs"></span>
                    </div>

                    <div class="col-md-6 form-group">
                        <label asp-for="Password" class="form-label">Password</label>
                        <input asp-for="Password" type="password" class="form-control" placeholder="Secure password" />
                        <span asp-validation-for="Password" class="text-danger text-xs"></span>
                    </div>

                    <div class="col-md-6 form-group">
                        <label asp-for="Fullname" class="form-label">Full Name</label>
                        <input asp-for="Fullname" class="form-control" placeholder="e.g. Robert Johnson" />
                        <span asp-validation-for="Fullname" class="text-danger text-xs"></span>
                    </div>

                    <div class="col-md-6 form-group">
                        <label asp-for="Email" class="form-label">Email Address</label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="admin@example.com" />
                        <span asp-validation-for="Email" class="text-danger text-xs"></span>
                    </div>

                    <div class="col-md-6 form-group">
                        <label asp-for="PhoneNumber" class="form-label">Phone Number</label>
                        <input asp-for="PhoneNumber" type="tel" class="form-control" placeholder="Phone number" />
                        <span asp-validation-for="PhoneNumber" class="text-danger text-xs"></span>
                    </div>

                    <div class="col-md-6 form-group">
                        <label asp-for="BranchId" class="form-label">Context Branch</label>
                        <select asp-for="BranchId" asp-items="Model.BranchOptions" class="form-select">
                            <option value="">-- All Branches / General --</option>
                        </select>
                        <span asp-validation-for="BranchId" class="text-danger text-xs"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4"><i class="bi bi-arrow-left me-1"></i> Cancel</a>
                    <button type="submit" class="btn btn-primary-custom px-4"><i class="bi bi-check-lg me-1"></i> Create Admin</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
