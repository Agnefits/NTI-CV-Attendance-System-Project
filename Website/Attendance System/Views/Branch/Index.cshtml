@model List<Attendance_System.ViewModels.Branch.BranchListViewModel>
@{
    ViewData["Title"] = "Branch Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="text-muted font-medium mb-0">System Branch Locations</h5>
    <a asp-action="Create" class="btn btn-primary-custom"><i class="bi bi-plus-lg me-1"></i> Add Branch</a>
</div>

<div class="row">
    @if (Model.Any())
    {
        foreach (var branch in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="branch-card h-100 d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="branch-icon-wrapper">
                                <i class="bi bi-building"></i>
                            </div>
                            <span class="branch-members-badge">
                                <i class="bi bi-people-fill"></i>
                                @branch.EmployeeCount Members
                            </span>
                        </div>
                        <h5 class="fw-bold mb-2 text-primary">@branch.Name</h5>
                        <p class="text-muted text-sm mb-4"><i class="bi bi-geo-alt-fill me-1"></i> @branch.Location</p>
                    </div>
                    
                    <div class="d-flex justify-content-end gap-2 border-top pt-3">
                        <a asp-action="Edit" asp-route-id="@branch.Id" class="btn btn-sm btn-outline-secondary px-3"><i class="bi bi-pencil-square me-1"></i> Edit</a>
                        <form asp-action="Delete" asp-route-id="@branch.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this branch?');" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-danger px-3"><i class="bi bi-trash me-1"></i> Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center text-muted py-5">
            <i class="bi bi-building fs-1 mb-2"></i>
            <p>No branch records are currently available. Click "Add Branch" to create one.</p>
        </div>
    }
</div>
