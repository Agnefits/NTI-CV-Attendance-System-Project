@model Attendance_System.ViewModels.Branch.BranchFormViewModel
@{
    ViewData["Title"] = "Edit Branch";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="custom-card">
            <h5 class="card-title mb-4"><i class="bi bi-pencil-square me-1"></i> Edit Branch Details</h5>
            
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-group mb-3">
                    <label asp-for="Name" class="form-label">Branch Name</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger text-xs"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="Location" class="form-label">Location Address</label>
                    <input asp-for="Location" class="form-control" />
                    <span asp-validation-for="Location" class="text-danger text-xs"></span>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4"><i class="bi bi-arrow-left me-1"></i> Cancel</a>
                    <button type="submit" class="btn btn-primary-custom px-4"><i class="bi bi-save me-1"></i> Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
