<!-- FACE ENROLLMENT PANEL STYLES (scoped)                          -->
<!-- ═══════════════════════════════════════════════════════════════ -->
<style>
  /* Step indicator */
  .enroll-step-bar { display:flex; align-items:center; gap:0; margin-bottom:2rem; }
  .enroll-step { display:flex; flex-direction:column; align-items:center; flex:1; position:relative; }
  .enroll-step:not(:last-child)::after {
    content:''; position:absolute; top:18px; left:calc(50% + 18px);
    width:calc(100% - 36px); height:2px; background:var(--border-color, #dee2e6); z-index:0;
  }
  .enroll-step.done::after, .enroll-step.active::after { background: linear-gradient(90deg,#6c63ff,#a855f7); }
  .enroll-step-icon {
    width:36px; height:36px; border-radius:50%; display:flex; align-items:center;
    justify-content:center; font-size:.85rem; font-weight:700; z-index:1; transition:.3s;
    background:#f1f3f5; color:#868e96; border:2px solid #dee2e6;
  }
  .enroll-step.active .enroll-step-icon { background:linear-gradient(135deg,#6c63ff,#a855f7); color:#fff; border-color:transparent; box-shadow:0 0 0 4px rgba(108,99,255,.18); }
  .enroll-step.done   .enroll-step-icon { background:linear-gradient(135deg,#22c55e,#16a34a); color:#fff; border-color:transparent; }
  .enroll-step-label  { font-size:.72rem; font-weight:600; margin-top:.35rem; color:#6c757d; text-align:center; }
  .enroll-step.active .enroll-step-label { color:#6c63ff; }
  .enroll-step.done   .enroll-step-label { color:#22c55e; }

  /* Tip cards */
  .angle-tip-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1rem; margin-bottom:1.5rem; }
  .angle-tip-card {
    background:linear-gradient(145deg,rgba(108,99,255,.06),rgba(168,85,247,.04));
    border:1.5px solid rgba(108,99,255,.18); border-radius:14px;
    padding:1rem .75rem; text-align:center; transition:.25s;
    cursor:pointer; position:relative; overflow:hidden;
  }
  .angle-tip-card:hover { border-color:#6c63ff; transform:translateY(-2px); box-shadow:0 6px 20px rgba(108,99,255,.12); }
  .angle-tip-card.selected { border-color:#6c63ff; background:rgba(108,99,255,.1); }
  .angle-tip-card.enrolled { border-color:#22c55e; background:rgba(34,197,94,.07); }
  .angle-tip-card .angle-figure {
    width:64px; height:64px; margin:0 auto .6rem; border-radius:50%;
    background:linear-gradient(135deg,#6c63ff22,#a855f722);
    display:flex; align-items:center; justify-content:center; font-size:2rem;
    border:2px dashed rgba(108,99,255,.35); position:relative; overflow:hidden;
  }
  .angle-tip-card.enrolled .angle-figure { border-color:#22c55e; background:rgba(34,197,94,.1); }
  .angle-face-svg { width:38px; height:38px; }
  .angle-label { font-size:.78rem; font-weight:700; color:#495057; margin-bottom:.2rem; }
  .angle-desc  { font-size:.7rem;  color:#868e96; line-height:1.3; }
  .angle-badge { position:absolute; top:6px; right:6px; width:20px; height:20px; border-radius:50%;
                 background:#22c55e; color:#fff; font-size:.62rem; display:none; align-items:center; justify-content:center; }
  .angle-tip-card.enrolled .angle-badge { display:flex; }

  /* Camera preview */
  .cam-wrap {
    position:relative; width:100%; max-width:380px; margin:0 auto;
    border-radius:16px; overflow:hidden; background:#0d0d0d;
    box-shadow:0 8px 30px rgba(0,0,0,.2);
  }
  #enrollVideo { width:100%; display:block; }
  #enrollCanvas { display:none; }
  .cam-overlay {
    position:absolute; inset:0; display:flex; align-items:center; justify-content:center;
    pointer-events:none;
  }
  .face-guide-box {
    width:52%; aspect-ratio:3/4; border:3px solid rgba(108,99,255,.7);
    border-radius:50%; box-shadow:0 0 0 4000px rgba(0,0,0,.35);
    animation:pulse-guide 2s ease-in-out infinite;
    display:flex; align-items:flex-end; justify-content:center;
  }
  @@keyframes pulse-guide { 0%,100%{ box-shadow:0 0 0 4000px rgba(0,0,0,.35),0 0 0 0 rgba(108,99,255,.4); } 50%{ box-shadow:0 0 0 4000px rgba(0,0,0,.4),0 0 0 12px rgba(108,99,255,.12); } }
  .cam-hint { position:absolute; bottom:10px; left:0; right:0; text-align:center; }
  .cam-hint span { background:rgba(0,0,0,.6); color:#fff; font-size:.72rem; padding:3px 12px; border-radius:20px; backdrop-filter:blur(4px); }
  .cam-no-device { padding:3rem 1rem; text-align:center; color:#868e96; }

  /* Upload slots */
  .upload-slot {
    border:2px dashed rgba(108,99,255,.3); border-radius:14px; padding:1rem;
    text-align:center; cursor:pointer; transition:.25s; position:relative; overflow:hidden;
    background:rgba(108,99,255,.03);
  }
  .upload-slot:hover { border-color:#6c63ff; background:rgba(108,99,255,.07); }
  .upload-slot.has-image { border-style:solid; border-color:#22c55e; background:rgba(34,197,94,.04); }
  .upload-slot img.preview { width:100%; height:100px; object-fit:cover; border-radius:8px; display:none; }
  .upload-slot.has-image img.preview { display:block; }
  .upload-slot.has-image .slot-placeholder { display:none; }
  .slot-placeholder i { font-size:1.8rem; color:rgba(108,99,255,.4); }
  .slot-placeholder small { display:block; font-size:.7rem; color:#868e96; margin-top:.3rem; }
  .upload-slot input[type=file] { position:absolute; inset:0; opacity:0; cursor:pointer; z-index:2; }

  /* Status pills */
  .enroll-status-row { display:flex; gap:.5rem; flex-wrap:wrap; margin-top:.75rem; }
  .enroll-pill { font-size:.72rem; padding:3px 10px; border-radius:20px; font-weight:600; display:flex; align-items:center; gap:.35rem; }
  .enroll-pill.pending  { background:rgba(108,99,255,.1); color:#6c63ff; }
  .enroll-pill.success  { background:rgba(34,197,94,.12); color:#16a34a; }
  .enroll-pill.error    { background:rgba(239,68,68,.1);  color:#dc2626; }
  .enroll-pill.loading  { background:rgba(251,191,36,.1); color:#d97706; }

  /* Enroll button */
  .btn-enroll {
    background:linear-gradient(135deg,#6c63ff,#a855f7); color:#fff; border:none;
    padding:.55rem 1.4rem; border-radius:10px; font-weight:600; font-size:.85rem;
    transition:.25s; display:inline-flex; align-items:center; gap:.45rem;
    box-shadow:0 4px 14px rgba(108,99,255,.25);
  }
  .btn-enroll:hover:not(:disabled) { transform:translateY(-1px); box-shadow:0 6px 20px rgba(108,99,255,.35); color:#fff; }
  .btn-enroll:disabled { opacity:.55; cursor:not-allowed; }

  /* Section headers */
  .enroll-section-head {
    display:flex; align-items:center; gap:.6rem; margin-bottom:.9rem;
    padding-bottom:.55rem; border-bottom:1px solid rgba(108,99,255,.12);
  }
  .enroll-section-head i { color:#6c63ff; font-size:1.05rem; }
  .enroll-section-head span { font-weight:700; font-size:.9rem; color:#343a40; }

  /* Or divider */
  .or-divider { display:flex; align-items:center; gap:.8rem; margin:1.2rem 0; color:#868e96; font-size:.8rem; font-weight:600; }
  .or-divider::before,.or-divider::after { content:''; flex:1; height:1px; background:rgba(108,99,255,.15); }

  /* Success overlay for card */
  .enroll-success-banner {
    display:none; background:linear-gradient(135deg,rgba(34,197,94,.1),rgba(16,185,129,.08));
    border:1.5px solid rgba(34,197,94,.3); border-radius:12px; padding:1rem 1.25rem;
    margin-top:1rem; align-items:center; gap:.75rem;
  }
  .enroll-success-banner.show { display:flex; }

  @@media(max-width:576px){
    .angle-tip-grid { grid-template-columns:1fr; }
    .cam-wrap { max-width:100%; }
  }
</style>

