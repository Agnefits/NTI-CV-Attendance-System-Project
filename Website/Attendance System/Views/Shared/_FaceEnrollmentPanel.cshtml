<!-- JAVASCRIPT                                                      -->
<!-- ═══════════════════════════════════════════════════════════════ -->
<script>
(function(){
  /* ── State ── */
  const SLOTS       = ['front','slight-left','slight-right'];
  const SLOT_LABELS = ['Front view','Slight Left','Slight Right'];
  const SLOT_ANGLES = ['front','slight-left','slight-right'];
  let capturedImages = [null, null, null];   // base64 strings
  let currentSlot    = 0;
  let stream         = null;

  /* ── Webcam init ── */
  const video      = document.getElementById('enrollVideo');
  const canvas     = document.getElementById('enrollCanvas');
  const camAvail   = document.getElementById('camAvailWrap');
  const camUnavail = document.getElementById('camUnavailMsg');
  const camBadge   = document.getElementById('camStatusBadge');
  const captureBtn = document.getElementById('captureBtn');

  async function initCam() {
    if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
      showNoCam(); return;
    }
    try {
      stream = await navigator.mediaDevices.getUserMedia({ video:{ facingMode:'user', width:640, height:480 }, audio:false });
      video.srcObject = stream;
      camAvail.classList.remove('d-none');
      camUnavail.classList.add('d-none');
      camBadge.textContent = 'Online';
      camBadge.style.background = 'rgba(34,197,94,.12)';
      camBadge.style.color = '#16a34a';
      captureBtn.disabled = false;
    } catch(e) {
      showNoCam();
    }
  }

  function showNoCam() {
    camAvail.classList.add('d-none');
    camUnavail.classList.remove('d-none');
    camBadge.textContent = 'Unavailable';
    camBadge.style.background = 'rgba(239,68,68,.1)';
    camBadge.style.color = '#dc2626';
  }

  /* ── Slot selection ── */
  window.selectSlot = function(idx) {
    currentSlot = idx;
    document.querySelectorAll('.angle-tip-card').forEach((c,i) =>
      c.classList.toggle('selected', i === idx));
    document.getElementById('slotName').textContent = SLOT_LABELS[idx];
    document.getElementById('camGuideLabel').textContent =
      ['Align face – looking straight','Align face – turn left ~30°','Align face – turn right ~30°'][idx];
  };

  /* ── Webcam capture ── */
  captureBtn && captureBtn.addEventListener('click', function() {
    if (!video.srcObject) return;
    canvas.width  = video.videoWidth  || 640;
    canvas.height = video.videoHeight || 480;
    canvas.getContext('2d').drawImage(video, 0, 0);
    const b64 = canvas.toDataURL('image/jpeg', .9).split(',')[1];
    storeCapture(currentSlot, b64, null);
    // Flash capture feedback
    captureBtn.innerHTML = '<i class="bi bi-check-lg"></i> Captured!';
    captureBtn.style.background = 'linear-gradient(135deg,#22c55e,#16a34a)';
    setTimeout(() => {
      captureBtn.innerHTML = '<i class="bi bi-camera"></i> Capture Current Angle';
      captureBtn.style.background = '';
    }, 900);
    // Auto-advance to next empty slot
    const nextEmpty = capturedImages.findIndex((v,i) => v === null && i !== currentSlot);
    if (nextEmpty !== -1) setTimeout(() => selectSlot(nextEmpty), 600);
  });

  /* ── File upload handler ── */
  window.onFileSelected = function(slotIdx, input) {
    const file = input.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = function(e) {
      const b64 = e.target.result.split(',')[1];
      const dataUrl = e.target.result;
      storeCapture(slotIdx, b64, dataUrl);
      // Show preview in upload slot
      const preview = document.getElementById('uploadPreview' + slotIdx);
      const slot    = document.getElementById('uploadSlot'   + slotIdx);
      preview.src = dataUrl;
      slot.classList.add('has-image');
    };
    reader.readAsDataURL(file);
  };

  /* ── Store a captured/uploaded image ── */
  function storeCapture(idx, b64, dataUrl) {
    capturedImages[idx] = b64;
    // Mark tip card as enrolled
    const cards = document.querySelectorAll('.angle-tip-card');
    if (cards[idx]) cards[idx].classList.add('enrolled');
    // Update button
    updateEnrollBtn();
    // Auto-select next empty for webcam
    selectSlot(idx);
  }

  /* ── Button state ── */
  function updateEnrollBtn() {
    const ready = capturedImages.filter(Boolean).length;
    const btn   = document.getElementById('enrollBtn');
    const txt   = document.getElementById('enrollBtnText');
    txt.textContent = `Enroll Face (${ready}/3 ready)`;
    btn.disabled    = (ready === 0);
  }

  /* ── Enrollment submission ── */
  window.submitEnrollment = async function() {
    const userId = document.getElementById('enrollTargetUserId').value;
    if (!userId) {
      addStatus('error', 'Save the record first, then enroll face.');
      return;
    }
    const toEnroll = capturedImages.map((b64, i) => b64 ? { image: b64, slot: i } : null).filter(Boolean);
    if (!toEnroll.length) return;

    const btn = document.getElementById('enrollBtn');
    btn.disabled = true;
    clearStatuses();
    addStatus('loading', `Sending ${toEnroll.length} image(s) to AI service…`);

    let ok = 0, fail = 0;
    for (const item of toEnroll) {
      try {
        const resp = await fetch('/FaceEnrollment/Enroll', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            userId:       userId,
            imageBase64:  item.image,
            captureAngle: SLOT_ANGLES[item.slot],
            label:        `Enrollment shot ${item.slot + 1} (${SLOT_LABELS[item.slot]})`
          })
        });
        const data = await resp.json();
        if (data.success) {
          ok++;
          addStatus('success', `Shot ${item.slot+1} ✓ Quality: ${(data.qualityScore*100).toFixed(0)}%`);
        } else {
          fail++;
          addStatus('error', `Shot ${item.slot+1} — ${data.message}`);
        }
      } catch(e) {
        fail++;
        addStatus('error', `Shot ${item.slot+1} — Network error`);
      }
    }

    btn.disabled = false;
    clearStatuses();
    if (ok > 0) {
      document.getElementById('enrollSuccessBanner').classList.add('show');
      document.getElementById('enrollSuccessDetail').textContent =
        `${ok} embedding(s) stored successfully.` + (fail > 0 ? ` ${fail} failed.` : '');
    }
    if (fail > 0 && ok === 0) {
      addStatus('error', `All ${fail} images failed. Check AI service connection.`);
    }
  };

  /* ── Clear embeddings (edit mode) ── */
  window.clearAllEmbeddings = async function() {
    const userId = document.getElementById('enrollTargetUserId').value;
    if (!userId || !confirm('Are you sure you want to delete ALL face data for this person? They will need to be re-enrolled.')) return;

    const btn = document.getElementById('clearEmbeddingsBtn');
    const statusEl = document.getElementById('clearStatus');
    btn.disabled = true;
    statusEl.innerHTML = '<span style="color:#d97706">Clearing…</span>';

    // We delete all embeddings one by one via preview + delete API
    try {
      const previewResp = await fetch(`/FaceEnrollment/Preview/${userId}`);
      const previewData = await previewResp.json();
      if (previewData.success && previewData.data.length > 0) {
        for (const emb of previewData.data) {
          await fetch('/FaceEnrollment/Delete/' + emb.id, { method:'POST' });
        }
        statusEl.innerHTML = `<span style="color:#22c55e"><i class="bi bi-check me-1"></i>${previewData.data.length} embedding(s) removed.</span>`;
        document.getElementById('enrollSuccessBanner').classList.remove('show');
        capturedImages = [null,null,null];
        document.querySelectorAll('.angle-tip-card').forEach(c => c.classList.remove('enrolled'));
        document.querySelectorAll('.upload-slot').forEach(s => s.classList.remove('has-image'));
        updateEnrollBtn();
      } else {
        statusEl.innerHTML = '<span style="color:#6c757d">No embeddings found.</span>';
      }
    } catch(e) {
      statusEl.innerHTML = '<span style="color:#dc2626">Error — could not connect.</span>';
    }
    btn.disabled = false;
  };

  /* ── Status helpers ── */
  function addStatus(type, msg) {
    const row = document.getElementById('enrollStatusRow');
    const pill = document.createElement('div');
    pill.className = `enroll-pill ${type}`;
    const icons = { success:'bi-check-circle-fill', error:'bi-x-circle-fill', loading:'bi-hourglass-split', pending:'bi-clock' };
    pill.innerHTML = `<i class="bi ${icons[type]||''}"></i>${msg}`;
    row.appendChild(pill);
  }
  function clearStatuses() {
    document.getElementById('enrollStatusRow').innerHTML = '';
  }

  /* ── Init ── */
  updateEnrollBtn();
  initCam();
})();
</script>
