@* 
    _FaceEnrollmentPanel.cshtml
    Shared Face Enrollment UI — included in Student & Employee Create/Edit pages.
    
    Parameters (passed via ViewData):
      ViewData["EnrollUserId"]   = Guid? (null on Create — enroll after save)
      ViewData["EnrollMode"]     = "create" | "edit"
      ViewData["EnrollUserName"] = string (display name)
*@
@{
    var userId     = ViewData["EnrollUserId"]   as string ?? "";
    var mode       = ViewData["EnrollMode"]     as string ?? "create";
    var userName   = ViewData["EnrollUserName"] as string ?? "this person";
    var isEdit     = mode == "edit";
}

