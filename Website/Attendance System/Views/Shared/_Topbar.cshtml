@{
    var title = ViewData["Title"] ?? "System Management";
}

<div class="topbar">
    <div class="d-flex align-items-center gap-3 min-width-0">
        <!-- Hamburger toggle — visible only on tablet/mobile -->
        <button class="sidebar-toggle-btn" id="sidebarToggleBtn" aria-label="Toggle navigation">
            <i class="bi bi-list"></i>
        </button>
        <h5 class="topbar-title">@title</h5>
    </div>
    
    <div class="topbar-actions">
        <div class="divider border-start h-50 mx-2 topbar-divider"></div>
        
        <div class="d-flex align-items-center gap-2 topbar-date">
            <span class="text-muted font-medium text-sm">@DateTime.Today.ToString("dd MMM yyyy")</span>
        </div>
    </div>
</div>
