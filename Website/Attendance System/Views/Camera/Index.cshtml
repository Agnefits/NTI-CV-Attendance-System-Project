@model List<Attendance_System.ViewModels.Camera.CameraListViewModel>
@{
    ViewData["Title"] = "Cameras Monitor";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="text-muted font-medium mb-0">AI Image Recognition Inputs</h5>
    <a asp-action="Create" class="btn btn-primary-custom"><i class="bi bi-plus-lg me-1"></i> Register Camera</a>
</div>

<div class="row">
    @if (Model.Any())
    {
        foreach (var camera in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="custom-card h-100 d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="fs-4 text-indigo"><i class="bi bi-camera-video"></i></span>
                            <span id="status-badge-@camera.Id" class="badge bg-success-subtle text-success border border-success px-2.5 py-1">
                                <i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i> Online
                            </span>
                        </div>
                        <h5 class="fw-bold mb-2 text-primary">@camera.Title</h5>
                        
                        <div class="text-sm text-muted mb-3 g-2">
                            <div class="mb-1"><i class="bi bi-door-open me-2"></i> Classroom: <strong>@camera.ClassRoomTitle</strong></div>
                            @if (!string.IsNullOrEmpty(camera.Location))
                            {
                                <div class="mb-1"><i class="bi bi-geo-alt me-2"></i> Location: @camera.Location</div>
                            }
                            <div class="mb-1 text-xs"><i class="bi bi-key me-2"></i> Key: <code class="text-secondary bg-light p-1 rounded">@camera.Key</code></div>
                        </div>

                        @if (!string.IsNullOrEmpty(camera.Notes))
                        {
                            <p class="text-xs text-muted font-medium bg-light p-2 rounded mb-3"><i class="bi-info-circle me-1"></i> @camera.Notes</p>
                        }
                    </div>

                    <div class="d-flex justify-content-between align-items-center border-top pt-3 mt-2">
                        <button type="button" class="btn btn-sm btn-outline-info px-3" onclick="testConnection('@camera.Id')">
                            <i class="bi bi-arrow-repeat me-1"></i> Ping test
                        </button>
                        <div class="d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@camera.Id" class="btn btn-sm btn-outline-secondary px-3"><i class="bi bi-pencil-square me-1"></i> Edit</a>
                            <form asp-action="Delete" asp-route-id="@camera.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this camera?');" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-danger px-3"><i class="bi bi-trash me-1"></i> Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center text-muted py-5">
            <i class="bi bi-camera-video fs-1 mb-2"></i>
            <p>No cameras registered. Click "Register Camera" to add one.</p>
        </div>
    }
</div>

@section Scripts {
    <script>
        function testConnection(id) {
            var badge = $('#status-badge-' + id);
            badge.removeClass('bg-success-subtle text-success border-success bg-danger-subtle text-danger border-danger');
            badge.addClass('bg-secondary-subtle text-secondary border-secondary');
            badge.html('<i class="spinner-border spinner-border-sm me-1" role="status"></i> Pinging...');

            $.ajax({
                url: '@Url.Action("TestConnection", "Camera")/' + id,
                type: 'GET',
                dataType: 'json',
                success: function (data) {
                    setTimeout(function() {
                        if (data.isOnline) {
                            badge.removeClass('bg-secondary-subtle text-secondary border-secondary');
                            badge.addClass('bg-success-subtle text-success border-success');
                            badge.html('<i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i> Online');
                        } else {
                            badge.removeClass('bg-secondary-subtle text-secondary border-secondary');
                            badge.addClass('bg-danger-subtle text-danger border-danger');
                            badge.html('<i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i> Offline');
                        }
                    }, 800);
                }
            });
        }
    </script>
}
