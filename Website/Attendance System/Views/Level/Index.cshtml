@model List<Attendance_System.ViewModels.Level.LevelListViewModel>
@{
    ViewData["Title"] = "Academic Levels";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="text-muted font-medium mb-0">List of Registered Levels</h5>
    <a asp-action="Create" class="btn btn-primary-custom"><i class="bi bi-plus-lg me-1"></i> Add Level</a>
</div>

<div class="custom-card">
    <div class="table-responsive-custom">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Linked Classes</th>
                    <th>Students Enrolled</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    foreach (var level in Model)
                    {
                        <tr>
                            <td class="fw-bold">@level.Title</td>
                            <td><span class="badge bg-secondary-subtle text-secondary border">@level.ClassCount Classes</span></td>
                            <td><span class="badge bg-info-subtle text-info border border-info">@level.StudentCount Students</span></td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@level.Id" class="btn btn-sm btn-outline-secondary px-3"><i class="bi bi-pencil-square me-1"></i> Edit</a>
                                <form asp-action="Delete" asp-route-id="@level.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this level? All associated classes and students will lose this link.');" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-danger px-3"><i class="bi bi-trash me-1"></i> Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">No academic levels found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
