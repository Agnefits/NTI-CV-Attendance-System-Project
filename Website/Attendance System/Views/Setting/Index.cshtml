@model Attendance_System.ViewModels.Setting.SettingListViewModel
@{
    ViewData["Title"] = "System Settings";
    var groupedSettings = Model.Settings.GroupBy(s => s.Group ?? "General Settings");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="text-muted font-medium mb-0">Configuration Variables</h5>
</div>

<form asp-action="Edit" method="post">
    @foreach (var group in groupedSettings)
    {
        <div class="custom-card mb-4">
            <h6 class="fw-bold text-xs text-muted uppercase border-bottom pb-2 mb-3"><i class="bi-sliders me-1"></i> @group.Key</h6>
            
            <div class="row g-3">
                @for (int i = 0; i < Model.Settings.Count; i++)
                {
                    if (Model.Settings[i].Group == group.Key || (string.IsNullOrEmpty(Model.Settings[i].Group) && group.Key == "General Settings"))
                    {
                        <input type="hidden" asp-for="Settings[i].Key" />
                        <input type="hidden" asp-for="Settings[i].Group" />
                        <input type="hidden" asp-for="Settings[i].Description" />

                        <div class="col-md-6 form-group">
                            <label class="form-label font-semibold">@Model.Settings[i].Key</label>
                            <input asp-for="Settings[i].Value" class="form-control" />
                            <span class="text-xxs text-muted">@Model.Settings[i].Description</span>
                        </div>
                    }
                }
            </div>
        </div>
    }

    <div class="text-end">
        <button type="submit" class="btn btn-primary-custom px-5"><i class="bi bi-save me-1"></i> Save Configurations</button>
    </div>
</form>
