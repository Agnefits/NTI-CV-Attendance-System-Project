@model Attendance_System.ViewModels.Profile.EditProfileViewModel
@{
    ViewData["Title"] = "Edit Profile";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="custom-card">
            <h5 class="card-title mb-4"><i class="bi bi-person-gear me-2"></i> Update Profile Information</h5>
            
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="d-flex align-items-center gap-4 mb-4">
                    <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/img/avatar-default.png" : Model.ImageUrl)" 
                         alt="Current Avatar" class="rounded-circle border" 
                         style="width: 80px; height: 80px; object-fit: cover;" 
                         onerror="this.src='/img/avatar-default.png'" />
                    <div class="form-group flex-grow-1">
                        <label asp-for="ImageFile" class="form-label">Profile Image</label>
                        <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
                        <span asp-validation-for="ImageFile" class="text-danger text-xs"></span>
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Fullname" class="form-label">Full Name</label>
                    <input asp-for="Fullname" class="form-control" required />
                    <span asp-validation-for="Fullname" class="text-danger text-xs"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Email" class="form-label">Email Address</label>
                    <input asp-for="Email" class="form-control" type="email" />
                    <span asp-validation-for="Email" class="text-danger text-xs"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="PhoneNumber" class="form-label">Phone Number</label>
                    <input asp-for="PhoneNumber" class="form-control" type="tel" />
                    <span asp-validation-for="PhoneNumber" class="text-danger text-xs"></span>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4"><i class="bi bi-arrow-left me-1"></i> Cancel</a>
                    <button type="submit" class="btn btn-primary-custom px-4"><i class="bi bi-save me-1"></i> Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
