@model Attendance_System.ViewModels.Student.StudentFormViewModel
@{
    ViewData["Title"] = "Register Student";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="custom-card">
            <h5 class="card-title mb-4"><i class="bi bi-plus-circle me-1"></i> Register New Student</h5>
            
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6 form-group">
                        <label asp-for="Username" class="form-label">Username</label>
                        <input asp-for="Username" class="form-control" placeholder="e.g. jsmith" />
                        <span asp-validation-for="Username" class="text-danger text-xs"></span>
                    </div>

                    <div class="col-md-6 form-group">
                        <label asp-for="Password" class="form-label">Password</label>
                        <input asp-for="Password" type="password" class="form-control" placeholder="Secure password" />
                        <span asp-validation-for="Password" class="text-danger text-xs"></span>
                    </div>

                    <div class="col-md-6 form-group">
                        <label asp-for="Fullname" class="form-label">Full Name</label>
                        <input asp-for="Fullname" class="form-control" placeholder="e.g. Jane Smith" />
                        <span asp-validation-for="Fullname" class="text-danger text-xs"></span>
                    </div>

                    <div class="col-md-6 form-group">
                        <label asp-for="Email" class="form-label">Email Address</label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="jane@example.com" />
                        <span asp-validation-for="Email" class="text-danger text-xs"></span>
                    </div>

                    <div class="col-md-6 form-group">
                        <label asp-for="PhoneNumber" class="form-label">Phone Number</label>
                        <input asp-for="PhoneNumber" type="tel" class="form-control" placeholder="Phone number" />
                        <span asp-validation-for="PhoneNumber" class="text-danger text-xs"></span>
                    </div>

                    <div class="col-md-6 form-group">
                        <label asp-for="ImageFile" class="form-label">Avatar Photo</label>
                        <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
                        <span asp-validation-for="ImageFile" class="text-danger text-xs"></span>
                    </div>

                    <div class="col-md-6 form-group">
                        <label asp-for="LevelId" class="form-label">Academic Level</label>
                        <select asp-for="LevelId" asp-items="Model.LevelOptions" class="form-select">
                            <option value="">-- Select Level --</option>
                        </select>
                        <span asp-validation-for="LevelId" class="text-danger text-xs"></span>
                    </div>

                    <div class="col-md-6 form-group">
                        <label asp-for="ClassId" class="form-label">Class Assignment</label>
                        <select asp-for="ClassId" asp-items="Model.ClassOptions" class="form-select">
                            <option value="">-- Select Class (Optional) --</option>
                        </select>
                        <span asp-validation-for="ClassId" class="text-danger text-xs"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4"><i class="bi bi-arrow-left me-1"></i> Cancel</a>
                    <button type="submit" class="btn btn-primary-custom px-4"><i class="bi bi-check-lg me-1"></i> Register Student</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
