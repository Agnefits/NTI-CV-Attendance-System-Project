@model Attendance_System.ViewModels.Student.StudentFormViewModel
@{
    ViewData["Title"] = "Edit Student";
    var studentId = Model.Id?.ToString() ?? "";
}

<div class="row justify-content-center">
    <div class="col-lg-9">

        <!-- ══ STUDENT INFO CARD ══════════════════════════════════════ -->
        <div class="custom-card mb-4">
            <h5 class="card-title mb-1"><i class="bi bi-pencil-square me-1"></i> Edit Student Registry</h5>
            <p class="text-muted mb-4" style="font-size:.82rem;">Update student details. Use Step 2 below to update their face biometrics.</p>

            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ImageUrl" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <!-- Avatar row -->
                <div class="d-flex align-items-center gap-4 mb-4 pb-3 border-bottom">
                    <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/img/avatar-default.png" : Model.ImageUrl)"
                         alt="Avatar" class="rounded-circle border"
                         style="width:70px;height:70px;object-fit:cover;"
                         onerror="this.src='/img/avatar-default.png'" />
                    <div class="form-group flex-grow-1">
                        <label asp-for="ImageFile" class="form-label">Upload New Photo</label>
                        <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
                        <span asp-validation-for="ImageFile" class="text-danger text-xs"></span>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-md-6 form-group">
                        <label asp-for="Username" class="form-label">Username</label>
                        <input asp-for="Username" class="form-control" />
                        <span asp-validation-for="Username" class="text-danger text-xs"></span>
                    </div>

                    <div class="col-md-6 form-group">
                        <label asp-for="Fullname" class="form-label">Full Name</label>
                        <input asp-for="Fullname" class="form-control" />
                        <span asp-validation-for="Fullname" class="text-danger text-xs"></span>
                    </div>

                    <div class="col-md-6 form-group">
                        <label asp-for="Email" class="form-label">Email Address</label>
                        <input asp-for="Email" type="email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger text-xs"></span>
                    </div>

                    <div class="col-md-6 form-group">
                        <label asp-for="PhoneNumber" class="form-label">Phone Number</label>
                        <input asp-for="PhoneNumber" type="tel" class="form-control" />
                        <span asp-validation-for="PhoneNumber" class="text-danger text-xs"></span>
                    </div>

                    <div class="col-md-6 form-group">
                        <label asp-for="LevelId" class="form-label">Academic Level</label>
                        <select asp-for="LevelId" asp-items="Model.LevelOptions" class="form-select"></select>
                        <span asp-validation-for="LevelId" class="text-danger text-xs"></span>
                    </div>

                    <div class="col-md-6 form-group">
                        <label asp-for="ClassId" class="form-label">Class Assignment</label>
                        <select asp-for="ClassId" asp-items="Model.ClassOptions" class="form-select">
                            <option value="">-- Select Class (Optional) --</option>
                        </select>
                        <span asp-validation-for="ClassId" class="text-danger text-xs"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-arrow-left me-1"></i> Cancel
                    </a>
                    <button type="submit" class="btn btn-primary-custom px-4">
                        <i class="bi bi-save me-1"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>

        <!-- ══ STEP 2 — FACE ENROLLMENT CARD ══════════════════════════ -->
        <div class="custom-card" id="faceEnrollCard">
            <!-- Collapsed header (toggle button) -->
            <div class="d-flex align-items-center justify-content-between" style="cursor:pointer;" id="enrollToggleRow" onclick="toggleEnrollPanel()">
                <div class="d-flex align-items-center gap-3">
                    <div style="width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,#6c63ff,#a855f7);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <i class="bi bi-shield-lock-fill" style="color:#fff;"></i>
                    </div>
                    <div>
                        <div style="font-weight:700;font-size:.95rem;">Step 2 — Update Face Biometrics</div>
                        <div style="font-size:.76rem;color:#6c757d;">Click to expand and re-enroll this student's face embeddings</div>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span id="enrollCountBadge" class="badge" style="background:rgba(108,99,255,.12);color:#6c63ff;font-size:.7rem;">
                        Loading…
                    </span>
                    <i class="bi bi-chevron-down" id="enrollChevron" style="color:#6c63ff;transition:.3s;"></i>
                </div>
            </div>

            <!-- Expandable panel -->
            <div id="enrollExpandPanel" class="d-none" style="margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid rgba(108,99,255,.12);">
                @{
                    ViewData["EnrollMode"]     = "edit";
                    ViewData["EnrollUserId"]   = studentId;
                    ViewData["EnrollUserName"] = Model.Fullname ?? "student";
                }
                <partial name="_FaceEnrollmentPanel" />
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    // ── Toggle expand/collapse ────────────────────────────────────────
    let enrollPanelOpen = false;
    window.toggleEnrollPanel = function() {
        enrollPanelOpen = !enrollPanelOpen;
        const panel   = document.getElementById('enrollExpandPanel');
        const chevron = document.getElementById('enrollChevron');
        panel.classList.toggle('d-none', !enrollPanelOpen);
        chevron.style.transform = enrollPanelOpen ? 'rotate(180deg)' : '';
        if (enrollPanelOpen) {
            document.getElementById('faceEnrollCard').scrollIntoView({ behavior:'smooth', block:'start' });
        }
    };

    // ── Load existing embedding count on page load ────────────────────
    (async function() {
        const userId = '@studentId';
        if (!userId) return;
        try {
            const resp = await fetch(`/FaceEnrollment/Preview/${userId}`);
            const data = await resp.json();
            const badge = document.getElementById('enrollCountBadge');
            if (data.success) {
                const n = data.data.length;
                badge.textContent = n > 0 ? `${n} embedding(s) stored` : 'No face data';
                badge.style.background = n > 0 ? 'rgba(34,197,94,.12)' : 'rgba(239,68,68,.08)';
                badge.style.color      = n > 0 ? '#16a34a' : '#dc2626';
            }
        } catch(e) {
            document.getElementById('enrollCountBadge').textContent = 'Unavailable';
        }
    })();
    </script>
}
