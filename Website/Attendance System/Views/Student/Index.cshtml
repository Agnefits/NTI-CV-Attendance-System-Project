@model Attendance_System.ViewModels.Student.StudentFilterViewModel
@{
    ViewData["Title"] = "Student Roster";
    var isAdmin = User.IsInRole("Admin");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="text-muted font-medium mb-0">List of Registered Students</h5>
    @if (isAdmin)
    {
        <a asp-action="Create" class="btn btn-primary-custom"><i class="bi bi-plus-lg me-1"></i> Add Student</a>
    }
</div>

<!-- Filters Panel -->
<div class="custom-card mb-4">
    <form asp-action="Index" method="get" class="row g-3 align-items-end">
        <div class="col-md-4 form-group">
            <label class="form-label" for="SearchQuery">Search Student</label>
            <input type="text" asp-for="SearchQuery" class="form-control" placeholder="Search by name, username or email..." />
        </div>
        <div class="col-md-3 form-group">
            <label class="form-label" for="LevelId">Academic Level</label>
            <select asp-for="LevelId" asp-items="Model.LevelOptions" class="form-select">
                <option value="">-- All Levels --</option>
            </select>
        </div>
        <div class="col-md-4 form-group">
            <label class="form-label" for="ClassId">Class</label>
            <select asp-for="ClassId" asp-items="Model.ClassOptions" class="form-select">
                <option value="">-- All Classes --</option>
            </select>
        </div>
        <div class="col-md-1">
            <button type="submit" class="btn btn-primary-custom w-100"><i class="bi bi-funnel-fill"></i></button>
        </div>
    </form>
</div>

<div class="custom-card">
    <div class="table-responsive-custom">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>Avatar</th>
                    <th>Name</th>
                    <th>Username</th>
                    <th>Level</th>
                    <th>Class</th>
                    <th>Email</th>
                    <th>Attendance %</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Results.Any())
                {
                    foreach (var s in Model.Results)
                    {
                        <tr>
                            <td>
                                <img src="@(string.IsNullOrEmpty(s.ImageUrl) ? "/img/avatar-default.png" : s.ImageUrl)" 
                                     alt="Avatar" class="rounded-circle border" 
                                     style="width: 40px; height: 40px; object-fit: cover;"
                                     onerror="this.src='/img/avatar-default.png'" />
                            </td>
                            <td class="fw-bold">@s.Fullname</td>
                            <td><code class="text-secondary bg-light p-1 rounded">@s.Username</code></td>
                            <td><span class="badge bg-secondary-subtle text-secondary border">@s.LevelTitle</span></td>
                            <td><span class="badge bg-primary-subtle text-primary border border-primary">@s.ClassTitle</span></td>
                            <td>@(s.Email ?? "-")</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress flex-grow-1" style="height: 6px; width: 60px;">
                                        <div class="progress-bar @(s.AttendancePercent >= 75 ? "bg-success" : (s.AttendancePercent >= 50 ? "bg-warning" : "bg-danger"))" 
                                             role="progressbar" style="width: @s.AttendancePercent%;"></div>
                                    </div>
                                    <span class="font-medium text-xs">@s.AttendancePercent%</span>
                                </div>
                            </td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@s.Id" class="btn btn-sm btn-outline-info px-3" title="Profile Details"><i class="bi bi-eye"></i></a>
                                @if (isAdmin)
                                {
                                    <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-sm btn-outline-secondary px-3"><i class="bi bi-pencil-square"></i></a>
                                    <form asp-action="Delete" asp-route-id="@s.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this student?');" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-danger px-3"><i class="bi bi-trash"></i></button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">No students registered matching criteria.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
