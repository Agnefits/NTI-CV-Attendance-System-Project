@model List<Attendance_System.ViewModels.ClassRoom.ClassRoomListViewModel>
@{
    ViewData["Title"] = "Classroom Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="text-muted font-medium mb-0">System Classrooms</h5>
    <a asp-action="Create" class="btn btn-primary-custom"><i class="bi bi-plus-lg me-1"></i> Add Classroom</a>
</div>

<div class="row">
    @if (Model.Any())
    {
        foreach (var room in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="custom-card h-100 d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <span class="fs-4 text-indigo"><i class="bi bi-door-open"></i></span>
                            <span class="badge bg-info-subtle text-info border border-info rounded-pill px-2.5 py-1">@room.CameraCount Cameras</span>
                        </div>
                        <h5 class="fw-bold mb-2 text-primary">@room.Title</h5>
                        <p class="text-muted text-sm mb-2"><i class="bi bi-geo-alt-fill me-1"></i> @room.Location</p>
                        @if (!string.IsNullOrEmpty(room.Notes))
                        {
                            <p class="text-xs text-muted font-medium bg-light p-2 rounded"><i class="bi bi-info-circle me-1"></i> @room.Notes</p>
                        }
                    </div>
                    
                    <div class="d-flex justify-content-end gap-2 border-top pt-3 mt-3">
                        <a asp-action="Edit" asp-route-id="@room.Id" class="btn btn-sm btn-outline-secondary px-3"><i class="bi bi-pencil-square me-1"></i> Edit</a>
                        <form asp-action="Delete" asp-route-id="@room.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this classroom?');" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-danger px-3"><i class="bi bi-trash me-1"></i> Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center text-muted py-5">
            <i class="bi bi-door-open fs-1 mb-2"></i>
            <p>No classrooms registered. Click "Add Classroom" to create one.</p>
        </div>
    }
</div>
