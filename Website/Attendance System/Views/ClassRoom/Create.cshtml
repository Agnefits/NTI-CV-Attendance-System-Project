@model Attendance_System.ViewModels.ClassRoom.ClassRoomFormViewModel
@{
    ViewData["Title"] = "Add Classroom";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="custom-card">
            <h5 class="card-title mb-4"><i class="bi bi-plus-circle me-1"></i> Add New Classroom</h5>
            
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-group mb-3">
                    <label asp-for="Title" class="form-label">Classroom Title</label>
                    <input asp-for="Title" class="form-control" placeholder="e.g. Room 101" />
                    <span asp-validation-for="Title" class="text-danger text-xs"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Location" class="form-label">Location</label>
                    <input asp-for="Location" class="form-control" placeholder="e.g. Main Block, Floor 1" />
                    <span asp-validation-for="Location" class="text-danger text-xs"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="Notes" class="form-label">Additional Notes</label>
                    <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Optional details..."></textarea>
                    <span asp-validation-for="Notes" class="text-danger text-xs"></span>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4"><i class="bi bi-arrow-left me-1"></i> Cancel</a>
                    <button type="submit" class="btn btn-primary-custom px-4"><i class="bi bi-check-lg me-1"></i> Create Classroom</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
