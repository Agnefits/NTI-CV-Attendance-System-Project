@model Attendance_System.ViewModels.Employee.EmployeeDetailsViewModel
@{
    ViewData["Title"] = $"{Model.Fullname} Details";
}

<div class="row">
    <!-- Left Column: Biography Details -->
    <div class="col-lg-4 mb-4">
        <div class="custom-card text-center">
            <div class="pb-3 border-bottom">
                <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/img/avatar-default.png" : Model.ImageUrl)" 
                     alt="Avatar" class="rounded-circle img-thumbnail mb-3" 
                     style="width: 120px; height: 120px; object-fit: cover;" 
                     onerror="this.src='/img/avatar-default.png'" />
                <h4 class="fw-bold mb-1">@Model.Fullname</h4>
                <p class="text-muted text-sm mb-2"><i class="bi bi-person-fill me-1"></i> @Model.JobTitle</p>
                <span class="badge bg-primary-subtle text-primary border border-primary px-3 py-1.5 rounded-pill text-xs">@Model.BranchName</span>
            </div>

            <div class="py-3 text-start text-sm">
                <div class="mb-2"><strong>Username:</strong> <code class="text-secondary bg-light p-1 rounded">@Model.Username</code></div>
                <div class="mb-2"><strong>Speciality:</strong> @Model.Speciality</div>
                <div class="mb-2"><strong>Email Address:</strong> @(Model.Email ?? "Not provided")</div>
                <div class="mb-0"><strong>Phone Number:</strong> @(Model.PhoneNumber ?? "Not provided")</div>
            </div>
        </div>
    </div>

    <!-- Right Column: Assigned Schedule Details -->
    <div class="col-lg-8 mb-4">
        <div class="custom-card h-100">
            <h5 class="card-title">Teacher Lesson Schedules</h5>
            <div class="table-responsive-custom mt-3">
                <table class="table-custom">
                    <thead>
                        <tr>
                            <th>Level</th>
                            <th>Class</th>
                            <th>Classroom</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Lessons.Any())
                        {
                            foreach (var lesson in Model.Lessons)
                            {
                                <tr>
                                    <td><span class="badge bg-secondary-subtle text-secondary border">@lesson.LevelTitle</span></td>
                                    <td class="fw-semibold text-primary">@lesson.ClassTitle</td>
                                    <td><span class="text-muted"><i class="bi bi-door-open-fill me-1"></i> @lesson.ClassRoomTitle</span></td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted py-4">No active lesson schedules assigned.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between mt-2">
    <a asp-action="Index" class="btn btn-outline-secondary px-4"><i class="bi bi-arrow-left me-1"></i> Back to Directory</a>
</div>
