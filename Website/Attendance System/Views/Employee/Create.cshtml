@model Attendance_System.ViewModels.Employee.EmployeeFormViewModel
@{
    ViewData["Title"] = "Add Employee";
}

<!-- ════════════════════════════════════════════════════
     STEP INDICATOR
════════════════════════════════════════════════════ -->
<div class="row justify-content-center mb-3">
    <div class="col-lg-9">
        <div class="enroll-step-bar">
            <div class="enroll-step active" id="stepBar1">
                <div class="enroll-step-icon">1</div>
                <div class="enroll-step-label">Employee Info</div>
            </div>
            <div class="enroll-step" id="stepBar2">
                <div class="enroll-step-icon"><i class="bi bi-shield-lock" style="font-size:.75rem;"></i></div>
                <div class="enroll-step-label">Face Enrollment</div>
            </div>
        </div>
    </div>
</div>

<!-- ════════════════════════════════════════════════════
     STEP 1 — EMPLOYEE INFO
════════════════════════════════════════════════════ -->
<div class="row justify-content-center" id="step1Panel">
    <div class="col-lg-9">
        <div class="custom-card">
            <h5 class="card-title mb-1"><i class="bi bi-person-badge me-1"></i> Register New Employee</h5>
            <p class="text-muted mb-4" style="font-size:.82rem;">Fill in the employee's details, then proceed to face enrollment.</p>

            <form asp-action="Create" method="post" enctype="multipart/form-data" id="employeeCreateForm">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6 form-group">
                        <label asp-for="Username" class="form-label">Username</label>
                        <input asp-for="Username" class="form-control" placeholder="e.g. jsmith" />
                        <span asp-validation-for="Username" class="text-danger text-xs"></span>
                    </div>

                    <div class="col-md-6 form-group">
                        <label asp-for="Password" class="form-label">Password</label>
                        <input asp-for="Password" type="password" class="form-control" placeholder="Secure password" />
                        <span asp-validation-for="Password" class="text-danger text-xs"></span>
                    </div>

                    <div class="col-md-6 form-group">
                        <label asp-for="Fullname" class="form-label">Full Name</label>
                        <input asp-for="Fullname" class="form-control" placeholder="e.g. John Doe" />
                        <span asp-validation-for="Fullname" class="text-danger text-xs"></span>
                    </div>

                    <div class="col-md-6 form-group">
                        <label asp-for="Email" class="form-label">Email Address</label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="john@example.com" />
                        <span asp-validation-for="Email" class="text-danger text-xs"></span>
                    </div>

                    <div class="col-md-6 form-group">
                        <label asp-for="PhoneNumber" class="form-label">Phone Number</label>
                        <input asp-for="PhoneNumber" type="tel" class="form-control" placeholder="Phone number" />
                        <span asp-validation-for="PhoneNumber" class="text-danger text-xs"></span>
                    </div>

                    <div class="col-md-6 form-group">
                        <label asp-for="ImageFile" class="form-label">Avatar Photo</label>
                        <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
                        <span asp-validation-for="ImageFile" class="text-danger text-xs"></span>
                    </div>

                    <div class="col-md-6 form-group">
                        <label asp-for="JobTitle" class="form-label">Job Title</label>
                        <input asp-for="JobTitle" class="form-control" placeholder="e.g. Teacher, HR Specialist"
                               list="jobTitleSuggestions" />
                        <datalist id="jobTitleSuggestions">
                            <option value="Teacher"></option>
                            <option value="Instructor"></option>
                            <option value="HR Specialist"></option>
                            <option value="Administrator"></option>
                            <option value="Accountant"></option>
                            <option value="IT Support"></option>
                            <option value="Security Guard"></option>
                            <option value="Principal"></option>
                        </datalist>
                        <span asp-validation-for="JobTitle" class="text-danger text-xs"></span>
                    </div>

                    <div class="col-md-6 form-group">
                        <label asp-for="Speciality" class="form-label">Speciality</label>
                        <input asp-for="Speciality" class="form-control" placeholder="e.g. Mathematics, Administration" />
                        <span asp-validation-for="Speciality" class="text-danger text-xs"></span>
                    </div>

                    <div class="col-md-6 form-group">
                        <label asp-for="BranchId" class="form-label">Branch Office</label>
                        <select asp-for="BranchId" asp-items="Model.BranchOptions" class="form-select">
                            <option value="">-- Unassigned --</option>
                        </select>
                        <span asp-validation-for="BranchId" class="text-danger text-xs"></span>
                    </div>
                </div>

                <!-- Action row -->
                <div class="d-flex justify-content-between align-items-center mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-arrow-left me-1"></i> Cancel
                    </a>
                    <div class="d-flex gap-2">
                        <button type="submit" name="skipEnroll" value="true"
                                class="btn btn-outline-secondary px-4">
                            <i class="bi bi-check-lg me-1"></i> Save Only
                        </button>
                        <button type="button" class="btn btn-primary-custom px-4" id="proceedToEnrollBtn">
                            <i class="bi bi-shield-lock me-1"></i> Save &amp; Enroll Face
                            <i class="bi bi-arrow-right ms-1"></i>
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- ════════════════════════════════════════════════════
     STEP 2 — FACE ENROLLMENT
════════════════════════════════════════════════════ -->
<div class="row justify-content-center d-none" id="step2Panel">
    <div class="col-lg-9">
        <div class="custom-card">
            <div class="d-flex align-items-center gap-3 mb-4">
                <div style="width:42px;height:42px;border-radius:50%;background:linear-gradient(135deg,#6c63ff,#a855f7);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <i class="bi bi-shield-lock-fill" style="color:#fff;font-size:1.1rem;"></i>
                </div>
                <div>
                    <h5 class="card-title mb-0">Step 2 — Face Biometric Enrollment</h5>
                    <p class="text-muted mb-0" style="font-size:.8rem;">Employee saved ✓ &nbsp;·&nbsp; Now enroll their face for AI attendance recognition</p>
                </div>
            </div>

            @{
                ViewData["EnrollMode"]     = "create";
                ViewData["EnrollUserId"]   = "";
                ViewData["EnrollUserName"] = "the new employee";
            }
            <partial name="_FaceEnrollmentPanel" />

            <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                <a asp-action="Index" class="btn btn-outline-secondary px-4">
                    <i class="bi bi-skip-forward me-1"></i> Skip &amp; Finish
                </a>
                <a asp-action="Index" class="btn btn-primary-custom px-4">
                    <i class="bi bi-check-all me-1"></i> Done — Back to List
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    document.getElementById('proceedToEnrollBtn').addEventListener('click', async function () {
        const form = document.getElementById('employeeCreateForm');
        // Use native HTML5 validation — avoids $.parseJSON compat issue with old jquery.validate.unobtrusive
        if (!form.checkValidity()) {
            form.reportValidity();
            return;
        }

        const btn = this;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Saving…';

        const fd = new FormData(form);
        fd.append('returnJson', 'true');
        try {
            const resp = await fetch(form.action, { method:'POST', body:fd });
            const ct = resp.headers.get('Content-Type') || '';
            if (ct.includes('application/json')) {
                const data = await resp.json();
                if (data.success && data.userId) {
                    document.getElementById('enrollTargetUserId').value = data.userId;
                    document.getElementById('step1Panel').classList.add('d-none');
                    document.getElementById('step2Panel').classList.remove('d-none');
                    document.getElementById('stepBar1').classList.replace('active','done');
                    document.getElementById('stepBar2').classList.add('active');
                    window.scrollTo({ top:0, behavior:'smooth' });
                    return;
                }
            } else {
                window.location = resp.url;
            }
        } catch(e) {
            alert('Network error — please try again.');
        }
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-shield-lock me-1"></i> Save &amp; Enroll Face <i class="bi bi-arrow-right ms-1"></i>';
    });
    </script>
}
