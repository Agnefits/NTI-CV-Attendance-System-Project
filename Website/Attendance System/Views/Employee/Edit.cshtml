@model Attendance_System.ViewModels.Employee.EmployeeFormViewModel
@{
    ViewData["Title"] = "Edit Employee";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="custom-card">
            <h5 class="card-title mb-4"><i class="bi bi-pencil-square me-1"></i> Edit Employee Registry</h5>
            
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ImageUrl" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="d-flex align-items-center gap-4 mb-4 pb-3 border-bottom">
                    <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/img/avatar-default.png" : Model.ImageUrl)" 
                         alt="Avatar" class="rounded-circle border" 
                         style="width: 70px; height: 70px; object-fit: cover;"
                         onerror="this.src='/img/avatar-default.png'" />
                    <div class="form-group flex-grow-1">
                        <label asp-for="ImageFile" class="form-label">Upload New Photo</label>
                        <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
                        <span asp-validation-for="ImageFile" class="text-danger text-xs"></span>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-md-6 form-group">
                        <label asp-for="Username" class="form-label">Username</label>
                        <input asp-for="Username" class="form-control" />
                        <span asp-validation-for="Username" class="text-danger text-xs"></span>
                    </div>

                    <div class="col-md-6 form-group">
                        <label asp-for="Fullname" class="form-label">Full Name</label>
                        <input asp-for="Fullname" class="form-control" />
                        <span asp-validation-for="Fullname" class="text-danger text-xs"></span>
                    </div>

                    <div class="col-md-6 form-group">
                        <label asp-for="Email" class="form-label">Email Address</label>
                        <input asp-for="Email" type="email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger text-xs"></span>
                    </div>

                    <div class="col-md-6 form-group">
                        <label asp-for="PhoneNumber" class="form-label">Phone Number</label>
                        <input asp-for="PhoneNumber" type="tel" class="form-control" />
                        <span asp-validation-for="PhoneNumber" class="text-danger text-xs"></span>
                    </div>

                    <div class="col-md-6 form-group">
                        <label asp-for="JobTitle" class="form-label">Job Title</label>
                        <input asp-for="JobTitle" class="form-control" list="jobTitleSuggestions" />
                        <datalist id="jobTitleSuggestions">
                            <option value="Teacher"></option>
                            <option value="Instructor"></option>
                            <option value="HR Specialist"></option>
                            <option value="Administrator"></option>
                            <option value="Accountant"></option>
                            <option value="IT Support"></option>
                            <option value="Security Guard"></option>
                            <option value="Principal"></option>
                        </datalist>
                        <span asp-validation-for="JobTitle" class="text-danger text-xs"></span>
                    </div>

                    <div class="col-md-6 form-group">
                        <label asp-for="Speciality" class="form-label">Speciality</label>
                        <input asp-for="Speciality" class="form-control" />
                        <span asp-validation-for="Speciality" class="text-danger text-xs"></span>
                    </div>

                    <div class="col-md-6 form-group">
                        <label asp-for="BranchId" class="form-label">Branch Office</label>
                        <select asp-for="BranchId" asp-items="Model.BranchOptions" class="form-select">
                            <option value="">-- Unassigned --</option>
                        </select>
                        <span asp-validation-for="BranchId" class="text-danger text-xs"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4"><i class="bi bi-arrow-left me-1"></i> Cancel</a>
                    <button type="submit" class="btn btn-primary-custom px-4"><i class="bi bi-save me-1"></i> Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
