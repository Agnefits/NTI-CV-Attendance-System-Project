@model Attendance_System.ViewModels.Employee.EmployeeFilterViewModel
@{
    ViewData["Title"] = "Employees Directory";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="text-muted font-medium mb-0">System Employees</h5>
    <a asp-action="Create" class="btn btn-primary-custom"><i class="bi bi-plus-lg me-1"></i> Add Employee</a>
</div>

<!-- Filters Panel -->
<div class="custom-card mb-4">
    <form asp-action="Index" method="get" class="row g-3 align-items-end">
        <div class="col-md-6 form-group">
            <label class="form-label" for="SearchQuery">Search Employee</label>
            <input type="text" asp-for="SearchQuery" class="form-control" placeholder="Search by name, job title, email or specialty..." />
        </div>
        <div class="col-md-5 form-group">
            <label class="form-label" for="BranchId">Branch Office</label>
            <select asp-for="BranchId" asp-items="Model.BranchOptions" class="form-select">
                <option value="">-- All Branches --</option>
            </select>
        </div>
        <div class="col-md-1">
            <button type="submit" class="btn btn-primary-custom w-100"><i class="bi bi-funnel-fill"></i></button>
        </div>
    </form>
</div>

<div class="row">
    @if (Model.Results.Any())
    {
        foreach (var emp in Model.Results)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="custom-card h-100 d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex align-items-center gap-3 mb-3 pb-3 border-bottom">
                            <img src="@(string.IsNullOrEmpty(emp.ImageUrl) ? "/img/avatar-default.png" : emp.ImageUrl)" 
                                 alt="Avatar" class="rounded-circle border" 
                                 style="width: 55px; height: 55px; object-fit: cover;"
                                 onerror="this.src='/img/avatar-default.png'" />
                            <div>
                                <h6 class="fw-bold mb-0 text-primary">@emp.Fullname</h6>
                                <span class="badge bg-primary-subtle text-primary border border-primary text-xs px-2 py-0.5 rounded-pill">@emp.JobTitle</span>
                            </div>
                        </div>
                        
                        <div class="text-sm text-muted mb-3 g-2">
                            <div class="mb-1"><i class="bi bi-tag me-2"></i> Speciality: <strong>@emp.Speciality</strong></div>
                            <div class="mb-1"><i class="bi bi-building me-2"></i> Branch: @emp.BranchName</div>
                            @if (!string.IsNullOrEmpty(emp.Email))
                            {
                                <div class="mb-1"><i class="bi bi-envelope me-2"></i> @emp.Email</div>
                            }
                            @if (!string.IsNullOrEmpty(emp.PhoneNumber))
                            {
                                <div class="mb-0"><i class="bi bi-telephone me-2"></i> @emp.PhoneNumber</div>
                            }
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center border-top pt-3 mt-2">
                        <a asp-action="Details" asp-route-id="@emp.Id" class="btn btn-sm btn-outline-info px-3"><i class="bi bi-eye me-1"></i> Details</a>
                        <div class="d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@emp.Id" class="btn btn-sm btn-outline-secondary px-3"><i class="bi bi-pencil-square me-1"></i> Edit</a>
                            <form asp-action="Delete" asp-route-id="@emp.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this employee?');" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-danger px-3"><i class="bi bi-trash me-1"></i> Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center text-muted py-5">
            <i class="bi bi-people fs-1 mb-2"></i>
            <p>No employees found matching search criteria.</p>
        </div>
    }
</div>
