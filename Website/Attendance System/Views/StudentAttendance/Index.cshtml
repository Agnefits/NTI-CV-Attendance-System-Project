@model Attendance_System.ViewModels.Attendance.StudentAttendanceFilterViewModel
@{
    ViewData["Title"] = "Student Attendance Ledger";
    var isStudent = User.IsInRole("Student");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="text-muted font-medium mb-0">Student Attendance Records</h5>
    <div class="d-flex gap-2">
        <a asp-action="ExportCsv" class="btn btn-outline-secondary"><i class="bi bi-file-earmark-spreadsheet me-1"></i> Export CSV</a>
        @if (!isStudent)
        {
            <a asp-action="Report" class="btn btn-outline-info"><i class="bi bi-bar-chart-line me-1"></i> View Report</a>
            <a asp-action="UploadImage" class="btn btn-outline-primary"><i class="bi bi-cpu me-1"></i> AI Scan</a>
            <a asp-action="Create" class="btn btn-primary-custom"><i class="bi bi-plus-lg me-1"></i> Manual Entry</a>
        }
    </div>
</div>

<!-- Filters Panel (For Admins and Teachers) -->
@if (!isStudent)
{
    <div class="custom-card mb-4">
        <form asp-action="Index" method="get" class="row g-3 align-items-end">
            <div class="col-md-3 form-group">
                <label class="form-label" for="SearchQuery">Search Student</label>
                <input type="text" asp-for="SearchQuery" class="form-control" placeholder="Search..." />
            </div>
            <div class="col-md-2 form-group">
                <label class="form-label" for="LevelId">Level</label>
                <select asp-for="LevelId" asp-items="Model.LevelOptions" class="form-select">
                    <option value="">-- All --</option>
                </select>
            </div>
            <div class="col-md-2 form-group">
                <label class="form-label" for="ClassId">Class</label>
                <select asp-for="ClassId" asp-items="Model.ClassOptions" class="form-select">
                    <option value="">-- All --</option>
                </select>
            </div>
            <div class="col-md-2 form-group">
                <label class="form-label" for="Status">Status</label>
                <select asp-for="Status" asp-items="Model.StatusOptions" class="form-select">
                    <option value="">-- All --</option>
                </select>
            </div>
            <div class="col-md-2 form-group">
                <label class="form-label" for="Date">Date</label>
                <input type="date" asp-for="Date" class="form-control" />
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-primary-custom w-100"><i class="bi bi-funnel-fill"></i></button>
            </div>
        </form>
    </div>
}

<!-- Logs Table -->
<div class="custom-card">
    <div class="table-responsive-custom">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>Student</th>
                    <th>Level/Class</th>
                    <th>Time Slot</th>
                    <th>Recorded Date/Time</th>
                    <th>Mode</th>
                    <th>Source Device</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Results.Any())
                {
                    foreach (var record in Model.Results)
                    {
                        <tr>
                            <td class="fw-bold">@record.StudentName <span class="text-muted text-xs">(@record.StudentUsername)</span></td>
                            <td><span class="badge bg-secondary-subtle text-secondary border">@record.LevelTitle / @record.ClassTitle</span></td>
                            <td class="fw-semibold">@record.LessonTimeSlot</td>
                            <td>@record.CreatedAt.ToString("g")</td>
                            <td>
                                @if (record.ByIA)
                                {
                                    <span class="text-indigo fw-medium"><i class="bi bi-cpu me-1"></i> AI Recognition</span>
                                }
                                else
                                {
                                    <span class="text-muted"><i class="bi bi-pencil me-1"></i> Manual</span>
                                }
                            </td>
                            <td>@(record.CameraTitle ?? "System Console")</td>
                            <td>
                                <partial name="_StatusBadge" model="record.Status" />
                            </td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@record.Id" class="btn btn-sm btn-outline-info px-3" title="View details"><i class="bi bi-eye"></i></a>
                                @if (!isStudent)
                                {
                                    <a asp-action="Edit" asp-route-id="@record.Id" class="btn btn-sm btn-outline-secondary px-3"><i class="bi bi-pencil-square"></i></a>
                                    <form asp-action="Delete" asp-route-id="@record.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this record?');" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-danger px-3"><i class="bi bi-trash"></i></button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">No student attendance records found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
