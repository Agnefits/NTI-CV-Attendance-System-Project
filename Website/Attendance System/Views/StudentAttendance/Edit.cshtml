@model Attendance_System.ViewModels.Attendance.StudentAttendanceFormViewModel
@{
    ViewData["Title"] = "Edit Student Attendance Log";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="custom-card">
            <h5 class="card-title mb-4"><i class="bi bi-pencil-square me-1"></i> Edit Student Attendance Log Entry</h5>
            
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ByIA" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-group mb-3">
                    <label asp-for="StudentId" class="form-label">Student</label>
                    <select asp-for="StudentId" asp-items="Model.StudentOptions" class="form-select" disabled></select>
                    <input type="hidden" asp-for="StudentId" />
                </div>

                <div class="form-group mb-3">
                    <label asp-for="LessonId" class="form-label">Lesson Time Slot</label>
                    <select asp-for="LessonId" asp-items="Model.LessonOptions" class="form-select">
                        <option value="">-- General Attendance --</option>
                    </select>
                    <span asp-validation-for="LessonId" class="text-danger text-xs"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Status" class="form-label">Attendance Status</label>
                    <select asp-for="Status" asp-items="Model.StatusOptions" class="form-select"></select>
                    <span asp-validation-for="Status" class="text-danger text-xs"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="CameraId" class="form-label">Camera Source</label>
                    <select asp-for="CameraId" asp-items="Model.CameraOptions" class="form-select">
                        <option value="">-- System Manual Console --</option>
                    </select>
                    <span asp-validation-for="CameraId" class="text-danger text-xs"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="Note" class="form-label">Notes</label>
                    <textarea asp-for="Note" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Note" class="text-danger text-xs"></span>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4"><i class="bi bi-arrow-left me-1"></i> Cancel</a>
                    <button type="submit" class="btn btn-primary-custom px-4"><i class="bi bi-save me-1"></i> Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
