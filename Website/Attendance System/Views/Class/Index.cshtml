@model Attendance_System.ViewModels.Class.ClassFilterViewModel
@{
    ViewData["Title"] = "Class Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="text-muted font-medium mb-0">Registered Classes</h5>
    <a asp-action="Create" class="btn btn-primary-custom"><i class="bi bi-plus-lg me-1"></i> Add Class</a>
</div>

<!-- Filters Panel -->
<div class="custom-card mb-4">
    <form asp-action="Index" method="get" class="row g-3 align-items-end">
        <div class="col-md-6 form-group">
            <label class="form-label" for="SearchQuery">Search Class</label>
            <input type="text" asp-for="SearchQuery" class="form-control" placeholder="Search by class title..." />
        </div>
        <div class="col-md-5 form-group">
            <label class="form-label" for="LevelId">Academic Level</label>
            <select asp-for="LevelId" asp-items="Model.LevelOptions" class="form-select">
                <option value="">-- All Levels --</option>
            </select>
        </div>
        <div class="col-md-1">
            <button type="submit" class="btn btn-primary-custom w-100"><i class="bi bi-funnel-fill"></i></button>
        </div>
    </form>
</div>

<div class="custom-card">
    <div class="table-responsive-custom">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Academic Level</th>
                    <th>Students Enrolled</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Results.Any())
                {
                    foreach (var c in Model.Results)
                    {
                        <tr>
                            <td class="fw-bold">@c.Title</td>
                            <td><span class="badge bg-primary-subtle text-primary border border-primary">@c.LevelTitle</span></td>
                            <td><span class="badge bg-info-subtle text-info border border-info">@c.StudentCount Students</span></td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-outline-secondary px-3"><i class="bi bi-pencil-square me-1"></i> Edit</a>
                                <form asp-action="Delete" asp-route-id="@c.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this class?');" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-danger px-3"><i class="bi bi-trash me-1"></i> Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">No classes found matching search criteria.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
