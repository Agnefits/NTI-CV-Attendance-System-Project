@model Attendance_System.ViewModels.Class.ClassFormViewModel
@{
    ViewData["Title"] = "Add Class";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="custom-card">
            <h5 class="card-title mb-4"><i class="bi bi-plus-circle me-1"></i> Add New Class</h5>
            
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-group mb-3">
                    <label asp-for="Title" class="form-label">Class Title</label>
                    <input asp-for="Title" class="form-control" placeholder="e.g. Class A" />
                    <span asp-validation-for="Title" class="text-danger text-xs"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="LevelId" class="form-label">Academic Level</label>
                    <select asp-for="LevelId" asp-items="Model.LevelOptions" class="form-select">
                        <option value="">-- Select Academic Level --</option>
                    </select>
                    <span asp-validation-for="LevelId" class="text-danger text-xs"></span>
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4"><i class="bi bi-arrow-left me-1"></i> Cancel</a>
                    <button type="submit" class="btn btn-primary-custom px-4"><i class="bi bi-check-lg me-1"></i> Create Class</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
