@model Attendance_System.ViewModels.Auth.ForgotPasswordViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Forgot Password";
}

<div class="auth-card">
    <div class="text-center mb-4">
        <i class="bi bi-envelope-fill" style="font-size: 3rem; color: var(--accent);"></i>
        <h3 class="fw-bold mt-2">Reset Password</h3>
        <p class="text-white-50 text-sm">Enter your email and we'll send you an OTP code to verify your identity.</p>
    </div>

    <form asp-action="ForgotPassword" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 text-sm"></div>

        <div class="form-group mb-4">
            <label asp-for="Email" class="form-label">Email Address</label>
            <div class="input-group">
                <span class="input-group-text bg-transparent border-end-0 border-light text-white-50"><i class="bi bi-envelope"></i></span>
                <input asp-for="Email" class="form-control border-start-0" placeholder="name@example.com" />
            </div>
            <span asp-validation-for="Email" class="text-danger text-xs"></span>
        </div>

        <button type="submit" class="btn btn-primary-custom w-100 py-2.5">
            <i class="bi bi-send me-2"></i> Send OTP Code
        </button>

        <div class="text-center mt-4">
            <a asp-action="Login" class="text-white-50 text-sm text-decoration-none hover-light"><i class="bi bi-arrow-left me-1"></i> Back to Login</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
