@model Attendance_System.ViewModels.Auth.LoginViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Login";
}

<div class="auth-card">
    <div class="text-center mb-4">
        <i class="bi bi-lock-fill" style="font-size: 3rem; color: var(--accent);"></i>
        <h3 class="fw-bold mt-2">Sign In</h3>
        <p class="text-white-50 text-sm">Attendance Monitoring System</p>
    </div>

    <form asp-action="Login" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 text-sm"></div>

        <div class="form-group mb-3">
            <label asp-for="Username" class="form-label">Username</label>
            <div class="input-group">
                <span class="input-group-text bg-transparent border-end-0 border-light text-white-50"><i class="bi bi-person"></i></span>
                <input asp-for="Username" class="form-control border-start-0" placeholder="Enter username" />
            </div>
            <span asp-validation-for="Username" class="text-danger text-xs"></span>
        </div>

        <div class="form-group mb-4">
            <label asp-for="Password" class="form-label">Password</label>
            <div class="input-group">
                <span class="input-group-text bg-transparent border-end-0 border-light text-white-50"><i class="bi bi-shield-lock"></i></span>
                <input asp-for="Password" type="password" class="form-control border-start-0" placeholder="Enter password" />
            </div>
            <span asp-validation-for="Password" class="text-danger text-xs"></span>
        </div>

        <div class="form-check mb-4">
            <input asp-for="RememberMe" class="form-check-input" />
            <label asp-for="RememberMe" class="form-check-label text-sm">Remember me</label>
        </div>

        <button type="submit" class="btn btn-primary-custom w-100 py-2.5">
            <i class="bi bi-box-arrow-in-right me-2"></i> Login
        </button>

        <div class="text-center mt-4">
            <a asp-action="ForgotPassword" class="text-white-50 text-sm text-decoration-none hover-light">Forgot your password?</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
