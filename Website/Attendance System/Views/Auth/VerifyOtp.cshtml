@model Attendance_System.ViewModels.Auth.VerifyOtpViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Verify OTP";
}

<div class="auth-card">
    <div class="text-center mb-4">
        <i class="bi bi-shield-check" style="font-size: 3rem; color: var(--accent);"></i>
        <h3 class="fw-bold mt-2">Enter Verification Code</h3>
        <p class="text-white-50 text-sm">We've sent a 6-digit OTP code to <strong class="text-white">@Model.Email</strong>.</p>
    </div>

    <form asp-action="VerifyOtp" method="post">
        <input type="hidden" asp-for="Email" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 text-sm"></div>

        <div class="form-group mb-4">
            <label asp-for="Otp" class="form-label">One-Time Password (OTP)</label>
            <div class="input-group">
                <span class="input-group-text bg-transparent border-end-0 border-light text-white-50"><i class="bi bi-key"></i></span>
                <input asp-for="Otp" class="form-control border-start-0 text-center fw-bold letter-spacing-lg" placeholder="123456" maxlength="6" />
            </div>
            <span asp-validation-for="Otp" class="text-danger text-xs"></span>
        </div>

        <button type="submit" class="btn btn-primary-custom w-100 py-2.5">
            <i class="bi bi-shield-lock me-2"></i> Verify & Proceed
        </button>

        <div class="text-center mt-4">
            <a asp-action="ForgotPassword" class="text-white-50 text-sm text-decoration-none hover-light"><i class="bi bi-arrow-left me-1"></i> Resend Code</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
